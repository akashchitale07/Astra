# ==============================================================================
#                      ASTRA ENVIRONMENT CONFIGURATION (.env)
# ==============================================================================
# Instructions:
# 1. Copy this file to '.env' in your local development root.
# 2. Fill in the external API keys (e.g., GEMINI_API_KEY).
# 3. For local secrets, robust development-safe defaults have been pre-generated.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. AI PROVIDER CONFIGURATIONS (Gemini & OpenAI)
# ------------------------------------------------------------------------------

# [REQUIRED] Gemini API Key - Powering Astra's primary chat model, deep research, and intent routing
# Leave empty for user-level API keys configured via the settings page.
# If configured globally here, it serves as the default system-wide intelligence key.
GEMINI_API_KEY=""

# [OPTIONAL] Default OpenAI Base URL for OpenAI-compatible proxies / models
# Defaults to https://api.openai.com/v1 if not specified.
DEFAULT_OPENAI_BASE_URL="https://api.openai.com/v1"


# ------------------------------------------------------------------------------
# 2. LOCAL SECRETS & ENCRYPTION KEYS (Cryptographically Secure Dev Defaults)
# ------------------------------------------------------------------------------

# [REQUIRED] JWT Secret Key - Used to sign and verify user authentication tokens
# Pre-generated secure 256-bit hex token for high-entropy local session signing.
JWT_SECRET_KEY="c412e690f05809ab7d6f5dfb8da13e31ab3f4cbbf6a73c18dbd8096123b04a9e"

# [OPTIONAL] JWT Cryptographic Hash Algorithm
# Allowed values: HS256, HS384, HS512 (Defaults to HS256)
JWT_ALGORITHM="HS256"

# [OPTIONAL] Access Token Expiry duration in minutes (1440 mins = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES="1440"

# [REQUIRED] API Key Encryption Secret (AES-256-CBC)
# Used in crypto.ts to securely encrypt/decrypt third-party API credentials stored in DB.
# Pre-generated 256-bit high-entropy secret key.
FERNET_KEY="8f6c12e9bcf281a8a256df3d00139b4fbc11ee8bbcf6903dcb085e33bf6d5a1b"

# [REQUIRED] Memory Vault Encryption Secret (AES-256-CBC)
# Used in memoryService.ts to encrypt/decrypt private long-term memories in SQLite.
# Pre-generated 256-bit high-entropy secret key.
MEMORY_ENCRYPTION_KEY="7cda0a6b5e0ab2d5f7881dc81de9f41bd37b4dbf7a42127d4cbbf6bc105a4b5f"


# ------------------------------------------------------------------------------
# 3. DATABASE CONFIGURATIONS (Drizzle / SQLite)
# ------------------------------------------------------------------------------

# [REQUIRED] Database Connection String
# Defaults to an embedded SQLite file 'astra.db' at project root.
# For Docker/Production, you can override with absolute file paths or RDS/SQL connections.
DATABASE_URL="sqlite:///./astra.db"


# ------------------------------------------------------------------------------
# 4. SERVER & DEPLOYMENT ENVIRONMENT
# ------------------------------------------------------------------------------

# [OPTIONAL] Application Environment Mode (development, production, testing)
APP_ENV="development"

# [OPTIONAL] Standard Node Execution Environment
# Handled in server.ts to trigger Vite dev middleware versus static production assets.
NODE_ENV="development"

# [OPTIONAL] Primary App URL - Used for absolute redirection, self-referencing, and OAuth callbacks
APP_URL="http://localhost:3000"

# [OPTIONAL] CORS Allowed Origins - Separated by commas
CORS_ORIGINS="http://localhost:3000"
